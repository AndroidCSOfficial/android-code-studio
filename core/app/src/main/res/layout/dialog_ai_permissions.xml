<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ai_file_write_permissions"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <CheckBox
        android:id="@+id/enableWriteCheckbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ai_enable_file_writing"
        android:layout_marginBottom="8dp"/>

    <CheckBox
        android:id="@+id/requireConfirmationCheckbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ai_require_confirmation"
        android:layout_marginBottom="8dp"/>

    <CheckBox
        android:id="@+id/autoBackupCheckbox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ai_auto_backup"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ai_file_write_warning"
        android:textSize="12sp"
        android:textColor="@android:color/holo_red_dark"
        android:layout_marginTop="8dp"/>
</LinearLayout>